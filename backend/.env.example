# ============================================================================
# CasaGuide — configuration de l'API (backend/.env)
# ----------------------------------------------------------------------------
# Copier ce fichier en `backend/.env` puis renseigner les valeurs. Le `.env`
# est chargé automatiquement au démarrage (M-02) et reste HORS dépôt (.gitignore).
# Ne jamais committer de vraies valeurs. Aucun secret en dur dans le code.
# ============================================================================

# ── Base de données PostgreSQL + PostGIS (partagée API et pipeline) ──────────
# Sans utilisateur explicite, psycopg prend l'utilisateur système (macOS/Homebrew).
CASAGUIDE_DB=postgresql://localhost/casaguide

# ── Signature des jetons JWT (HS256) ─────────────────────────────────────────
# Générer : openssl rand -hex 32
# Si absente : une clé éphémère est générée par processus → les jetons émis
# sont invalidés à chaque redémarrage (à définir impérativement en production).
CASAGUIDE_JWT_SECRET=

# ── Chiffrement AES-256 des secrets (wifi, boîte à clés — §8) ────────────────
# Générer : openssl rand -hex 32   (32 octets, hex 64 caractères ou base64)
# Si absente : les endpoints de secrets répondent 503 (aucune donnée en clair).
CASAGUIDE_SECRET_KEY=

# ── Clé API Anthropic (enrichissement IA) ────────────────────────────────────
# Requise uniquement pour lancer le pipeline d'enrichissement.
ANTHROPIC_API_KEY=

# ── Stockage des médias (photos/PDF des sections — M-12) ─────────────────────
# Répertoire local ; relatif à backend/ s'il n'est pas absolu. Exclu de git.
# Architecture prête pour un backend S3 (voir api/storage.py).
MEDIA_ROOT=var/media

# ── Options (valeurs par défaut raisonnables — décommenter pour surcharger) ──
# CASAGUIDE_MODEL=claude-sonnet-4-6
# Traduction du guide voyageur (M-09) : modèle dédié (Haiku suffit, ~3× moins
# cher que Sonnet) et langues cibles MVP (langue source = default_lang, exclue).
# CASAGUIDE_TRANSLATE_MODEL=claude-haiku-4-5-20251001
# CASAGUIDE_TRANSLATE_LANGS=en,es
# CASAGUIDE_JWT_EXPIRE_MIN=10080
# CASAGUIDE_CORS_ORIGINS=*
# CASAGUIDE_GUIDE_CACHE_S=300
# CASAGUIDE_MAX_UPLOAD_BYTES=10485760
