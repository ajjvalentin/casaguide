# ============================================================================
# CasaGuide — reverse proxy Caddy (M-11, bascule domaine M-27)
# ----------------------------------------------------------------------------
# Installation :
#   sudo cp /opt/casaguide/ops/Caddyfile /etc/caddy/Caddyfile
#   sudo caddy validate --config /etc/caddy/Caddyfile --adapter caddyfile
#   sudo systemctl reload caddy
#
# État actuel (M-27, 17/07/2026) : HTTPS de confiance sur le domaine technique
# provisoire « guide.holaquetalimmo.es ».
#   · guide.holaquetalimmo.es → certificat Let's Encrypt obtenu et renouvelé
#     AUTOMATIQUEMENT par Caddy ; redirection http→https automatique ; HSTS actif.
#   · L'ancienne adresse par IP (179.237.85.250, http ET https) → redirection 301
#     PERMANENTE vers le domaine : les liens/QR déjà partagés continuent de mener
#     au guide. (Le https par IP garde un cert auto-signé `tls internal` — il ne
#     sert qu'à rediriger ; Let's Encrypt ne délivre pas de cert pour une IP.)
#
# Le HTTPS de confiance débloque le mode PWA hors-ligne complet (service worker,
# M-10).
#
# ─── DOMAINE DÉFINITIF (le jour venu) ──────────────────────────────────────────
# « guide.holaquetalimmo.es » est un domaine TECHNIQUE PROVISOIRE. Quand la marque
# définitive sera choisie : créer un enregistrement A du nouveau domaine vers
# 179.237.85.250, ajouter son bloc de site ci-dessous (Caddy obtient le cert
# automatiquement), faire pointer l'ancien domaine en redir 301 vers le nouveau
# (comme l'IP ci-dessous), puis basculer CASAGUIDE_PUBLIC_BASE_URL /
# CASAGUIDE_CORS_ORIGINS dans backend/.env.
# ============================================================================
{
	# Contact Let's Encrypt (avis d'expiration / problèmes de certificat).
	email av@weemo.ch
}

# En-têtes de sécurité mutualisés. HSTS activé (HTTPS de confiance) — max-age
# volontairement modéré pour commencer (180 j), includeSubDomains, SANS preload
# (le preload est irréversible et engloberait tout le domaine : à n'activer que
# plus tard, en connaissance de cause).
(securite) {
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		Strict-Transport-Security "max-age=15552000; includeSubDomains"
		# On ne divulgue pas la stack
		-Server
	}
}

# Guide public — HTTPS de confiance (Let's Encrypt, http→https automatique).
guide.holaquetalimmo.es {
	encode zstd gzip
	reverse_proxy 127.0.0.1:8000
	import securite
	log {
		output file /var/log/caddy/access.log
		format json
	}
}

# Ancienne adresse par IP → redirection permanente vers le domaine, en http comme
# en https (cert auto-signé conservé uniquement pour honorer la redirection TLS).
http://179.237.85.250 {
	redir https://guide.holaquetalimmo.es{uri} permanent
}
https://179.237.85.250 {
	tls internal
	redir https://guide.holaquetalimmo.es{uri} permanent
}
