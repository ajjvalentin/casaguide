# ============================================================================
# CasaGuide — reverse proxy Caddy (M-11, bascule domaine M-27, marque M-28)
# ----------------------------------------------------------------------------
# Installation :
#   sudo cp /opt/casaguide/ops/Caddyfile /etc/caddy/Caddyfile
#   sudo caddy validate --config /etc/caddy/Caddyfile --adapter caddyfile
#   sudo systemctl reload caddy
#
# État actuel (M-28, 19/07/2026) : la marque « Holaguia » est l'adresse
# CANONIQUE du produit. Une seule adresse de service, tout le reste y redirige.
#   · https://holaguia.com            → LE PRODUIT (back-office /, guides /g/,
#                                        cahier équipe /s/). Cert Let's Encrypt
#                                        obtenu et renouvelé AUTOMATIQUEMENT.
#   · https://www.holaguia.com        → 301 vers https://holaguia.com{uri}
#   · https://holaguia.ch             → 301 vers https://holaguia.com{uri}
#   · https://guide.holaquetalimmo.es → 301 vers https://holaguia.com{uri}
#     (ANCIEN domaine technique M-27 : garde son cert Let's Encrypt pour honorer
#      la redirection https propre → chaque lien/QR déjà partagé survit)
#   · http(s)://179.237.85.250        → 301 vers https://holaguia.com{uri}
#     (cert auto-signé conservé uniquement pour honorer la redirection TLS ;
#      Let's Encrypt ne délivre pas de cert pour une IP)
#
# Ces 4 noms (holaguia.com, www.holaguia.com, holaguia.ch,
# guide.holaquetalimmo.es) RÉSOLVENT vers 179.237.85.250 et obtiennent leur cert
# Let's Encrypt via tls-alpn-01.
#
# EN ATTENTE — holaguia.es : la délégation .es n'est PAS encore publiée (le nom ne
# résout pas). Son bloc est PRÊT mais COMMENTÉ plus bas : le décommenter dès que
# `dig +short holaguia.es` renvoie 179.237.85.250 (sinon Caddy échoue en boucle
# sur le challenge tls-alpn-01, faute de DNS). Cf. deploiement.md §4.
#
# NB : holaquetalimmo.es héberge le SITE IMMOBILIER — seul le sous-domaine
# « guide » nous concerne ; ne JAMAIS toucher un autre enregistrement.
# ============================================================================
{
	# Contact Let's Encrypt (avis d'expiration / problèmes de certificat).
	email av@weemo.ch
}

# En-têtes de sécurité mutualisés. HSTS activé (HTTPS de confiance) — max-age
# volontairement modéré pour commencer (180 j), includeSubDomains, SANS preload
# (le preload est irréversible et engloberait tout le domaine : à n'activer que
# plus tard, en connaissance de cause).
(securite) {
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		Strict-Transport-Security "max-age=15552000; includeSubDomains"
		# On ne divulgue pas la stack
		-Server
	}
}

# ─── Adresse canonique du produit ───────────────────────────────────────────
holaguia.com {
	encode zstd gzip
	reverse_proxy 127.0.0.1:8000
	import securite
	log {
		output file /var/log/caddy/access.log
		format json
	}
}

# ─── Redirections 301 vers l'adresse canonique ──────────────────────────────
# www + variante de marque .ch + ancien domaine technique (M-27). Ces noms
# RÉSOLVENT : Caddy obtient un cert Let's Encrypt pour chacun (redirection
# https propre).
www.holaguia.com,
holaguia.ch,
guide.holaquetalimmo.es {
	redir https://holaguia.com{uri} permanent
}

# ─── EN ATTENTE : holaguia.es (délégation .es non encore publiée) ────────────
# À DÉCOMMENTER quand `dig +short holaguia.es` renvoie 179.237.85.250. Tant que
# le nom ne résout pas, le laisser commenté : Caddy échouerait en boucle sur le
# challenge tls-alpn-01 (aucun cert possible sans DNS pointant sur ce serveur).
# Geste : décommenter le bloc, puis
#   sudo cp /opt/casaguide/ops/Caddyfile /etc/caddy/Caddyfile
#   sudo caddy validate --config /etc/caddy/Caddyfile --adapter caddyfile
#   sudo systemctl reload caddy
# (le monitor DNS armé le jour de la bascule le fait automatiquement ; cf.
#  deploiement.md §4).
# holaguia.es {
# 	redir https://holaguia.com{uri} permanent
# }

# Ancienne adresse par IP → redirection permanente, en http comme en https
# (cert auto-signé conservé uniquement pour honorer la redirection TLS).
http://179.237.85.250 {
	redir https://holaguia.com{uri} permanent
}
https://179.237.85.250 {
	tls internal
	redir https://holaguia.com{uri} permanent
}
